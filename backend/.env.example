DATABASE_URL=postgresql+psycopg_async://postgres:postgres@localhost:5432/workflow_db
SECRET_KEY=replace-with-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Phase 3 — set REDIS_URL to enable queue + worker (omit for local sync-only POST /jobs/{id}/run)
REDIS_URL=redis://localhost:6379/0
QUEUE_NAME=workflow:jobs
DLQ_NAME=workflow:dlq
DEFAULT_MAX_ATTEMPTS=3
WORKER_BRPOP_TIMEOUT=5
JOB_LOCK_TTL_SECONDS=300
RETRY_BACKOFF_CAP_SECONDS=60
RETRY_ON_WORKFLOW_FAILURE=false
